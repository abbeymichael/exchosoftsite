APP_NAME=ExchoLicense
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database ───────────────────────────────────────────────────────────────────
# For production use MySQL / PostgreSQL
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=excholicense
# DB_USERNAME=root
# DB_PASSWORD=

# ── Session ────────────────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ── Queues & Cache ─────────────────────────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# ── Redis (optional — faster cache/queue for production) ──────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail ───────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@exchosoft.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Main Admin (used by AdminSeeder) ──────────────────────────────────────────
# Set these before running `php artisan db:seed` in production
MAIN_ADMIN_EMAIL=admin@exchosoft.com
MAIN_ADMIN_PASSWORD=Exchosoft@2024!
MAIN_ADMIN_NAME="ExchoSoft Admin"

# ── Storage (for avatar uploads) ──────────────────────────────────────────────
# Run `php artisan storage:link` after deploy
FILESYSTEM_DISK=public

# ── Currency ───────────────────────────────────────────────────────────────────
# All monetary values are in Ghana Cedis (GHS)
APP_CURRENCY=GHS
APP_CURRENCY_SYMBOL=GHS

# ── Vite ───────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
